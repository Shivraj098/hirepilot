// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}

enum VersionType {
  BASE
  TAILORED
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resumes        Resume[]
  resumeVersions ResumeVersion[]
  jobs           Job[]
  applications   JobApplication[]
  sessions       Session[]
  accounts       Account[]

  resumeAnalyses    ResumeAnalysis[]
  activities        Activity[]
  matchResults      MatchResult[]
  tailorResults     TailorResult[]
  scoreHistories    ScoreHistory[]
  jobAnalyses       JobAnalysis[]
  linkedinProfiles  LinkedinProfile[]
  portfolioProfiles PortfolioProfile[]
}

model Resume {
  id     String @id @default(uuid())
  userId String
  title  String

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions ResumeVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ResumeVersion {
  id       String  @id @default(uuid())
  resumeId String
  userId   String
  jobId    String?
  content  Json

  versionType VersionType @default(BASE)
  parentId    String?

  label         String?
  createdBy     String?
  notes         String?
  scoreSnapshot Int?

  createdAt DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  job    Job?   @relation(fields: [jobId], references: [id])

  parent   ResumeVersion?  @relation("VersionBranch", fields: [parentId], references: [id])
  children ResumeVersion[] @relation("VersionBranch")

  applications JobApplication[]
  aTSResults   ATSResult[]
  suggestions  AISuggestion[]

  // ✅ ADD THESE TWO (only once)

  tailorBaseResults TailorResult[]   @relation("TailorBase")
  tailorNewResults  TailorResult[]   @relation("TailorNew")
  skillGaps         SkillGap[]
  interviewPreps    InterviewPrep[]
  resumeAnalyses    ResumeAnalysis[]
  matchResults      MatchResult[]
  scoreHistories    ScoreHistory[]
}

model Job {
  id          String  @id @default(uuid())
  userId      String
  title       String
  company     String
  location    String?
  jobLink     String?
  description String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status JobStatus @default(SAVED)
  notes  String?

  // NEW 
  appliedAt   DateTime?
  interviewAt DateTime?
  offerAt     DateTime?
  rejectedAt  DateTime?

  priority   String? // LOW / MEDIUM / HIGH
  source     String? // LinkedIn / Referral / Company site
  isFavorite Boolean @default(false)

  user           User             @relation(fields: [userId], references: [id])
  applications   JobApplication[]
  versions       ResumeVersion[]
  skillGaps      SkillGap[]
  interviewPreps InterviewPrep[]
  matchResults   MatchResult[]
  tailorResults  TailorResult[]
  jobAnalyses    JobAnalysis[]
}

model JobApplication {
  id              String @id @default(uuid())
  userId          String
  jobId           String
  resumeVersionId String

  status JobStatus @default(SAVED)
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //  NEW
  appliedAt   DateTime?
  interviewAt DateTime?
  offerAt     DateTime?
  rejectedAt  DateTime?

  scoreSnapshot Int?

  user          User          @relation(fields: [userId], references: [id])
  job           Job           @relation(fields: [jobId], references: [id])
  resumeVersion ResumeVersion @relation(fields: [resumeVersionId], references: [id])
}

model ATSResult {
  id              String   @id @default(uuid())
  resumeVersionId String   @unique
  score           Int
  matchedKeywords Json
  missingKeywords Json
  weakKeywords    Json
  createdAt       DateTime @default(now())

  resumeVersion ResumeVersion @relation(fields: [resumeVersionId], references: [id])
}

model AISuggestion {
  id               String   @id @default(uuid())
  resumeVersionId  String
  section          String
  originalContent  Json
  suggestedContent Json
  applied          Boolean  @default(false)
  createdAt        DateTime @default(now())

  resumeVersion ResumeVersion @relation(fields: [resumeVersionId], references: [id])
}

model SkillGap {
  id    String @id @default(uuid())
  jobId String

  skill         String
  priority      String
  estimatedTime String
  reasoning     String

  difficulty      String? // NEW
  learningLink    String? // NEW
  resumeVersionId String?
  resumeVersion   ResumeVersion? @relation(fields: [resumeVersionId], references: [id])

  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id])
}

model InterviewPrep {
  id    String @id @default(uuid())
  jobId String

  questions       Json
  starDrafts      Json
  technicalTopics Json

  type            String
  resumeVersionId String?
  resumeVersion   ResumeVersion? @relation(fields: [resumeVersionId], references: [id])

  createdAt DateTime @default(now())

  // NEW

  difficulty String? // EASY / MEDIUM / HARD
  category   String? // HR / TECH / MIXED

  notes String?

  rating Int? // future user feedback

  summary String? // AI summary of prep

  status String? // NEW / REVIEWED / PRACTICED

  job Job @relation(fields: [jobId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ResumeAnalysis {
  id String @id @default(uuid())

  resumeVersionId String
  userId          String

  score    Int?
  atsScore Int?

  profileScore    Int?
  contentScore    Int?
  skillScore      Int?
  experienceScore Int?

  strengths         Json?
  weaknesses        Json?
  recommendedSkills Json?

  createdAt DateTime @default(now())

  resumeVersion ResumeVersion @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id String @id @default(uuid())

  userId String

  type       String
  entityType String?
  entityId   String?

  message String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MatchResult {
  id String @id @default(uuid())

  resumeVersionId String
  jobId           String
  userId          String

  matchScore  Int?
  fitLevel    String?
  shouldApply Boolean?

  missingSkills Json?
  reason        String?

  createdAt DateTime @default(now())

  resumeVersion ResumeVersion @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)
  job           Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TailorResult {
  id String @id @default(uuid())

  baseVersionId String
  newVersionId  String
  jobId         String
  userId        String

  createdAt DateTime @default(now())

  baseVersion ResumeVersion @relation("TailorBase", fields: [baseVersionId], references: [id])
  newVersion  ResumeVersion @relation("TailorNew", fields: [newVersionId], references: [id])

  job  Job  @relation(fields: [jobId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model ScoreHistory {
  id String @id @default(uuid())

  resumeVersionId String
  userId          String

  score    Int?
  atsScore Int?

  createdAt DateTime @default(now())

  resumeVersion ResumeVersion @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobAnalysis {
  id String @id @default(uuid())

  jobId  String
  userId String

  roleCategory  String?
  requiredLevel String?
  difficulty    String?
  domain        String?

  importantSkills Json?
  secondarySkills Json?

  createdAt DateTime @default(now())

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LinkedinProfile {
  id String @id @default(uuid())

  userId String

  rawText Json?

  analysis Json?

  score Int?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PortfolioProfile {
  id String @id @default(uuid())

  userId String

  rawText Json?

  analysis Json?

  score Int?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model AICache {
  id        String   @id @default(uuid())

  key       String   @unique
  prompt    String
  result    Json

  createdAt DateTime @default(now())
}